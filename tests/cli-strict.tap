#    https://imagemagick.org/license/
#
#  Unless required by applicable law or agreed to in writing, software
#  distributed under the License is distributed on an "AS IS" BASIS,
#  WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
#  See the License for the specific language governing permissions and
#  limitations under the License.
#
#  Regression tests for the -strict option (#8682).
#
. ./common.shi
. ${srcdir}/tests/common.shi

# Skip if TIFF support was not compiled in or if libtiff has JBIG2 (rare,
# but would make the unsupported-codec probe pass and break the negative
# test).
formats=`${MAGICK} -list format 2>/dev/null`
echo "$formats" | grep -qi '^[ ]*TIFF' || {
  echo "1..0 # SKIP TIFF coder not compiled in"
  exit 0
}
${MAGICK} -list configure 2>/dev/null | grep -qi 'JBIG2' && {
  echo "1..0 # SKIP libtiff has JBIG2 support"
  exit 0
}

echo "1..6"

out="cli-strict_out.tiff"

# 1. Without -strict, requesting an unsupported compression silently falls
# back to no compression and exits 0 (legacy behavior preserved).
${MAGICK} ${SRCDIR}/rose.pnm -compress JBIG2 "$out" 2>/dev/null \
  && echo "ok" || echo "not ok"

# 2. With -strict, the same request must fail with a non-zero exit and
# emit a CompressionNotSupported error from the TIFF coder. Reject the
# locale-translated "unrecognized option" so an unpatched build does
# not pass.
err=`${MAGICK} -strict ${SRCDIR}/rose.pnm -compress JBIG2 "$out" 2>&1`
status=$?
case "$err" in
  *unrecognized*option*) echo "not ok" ;;
  *)
    if [ $status -eq 0 ]; then
      echo "not ok"
    else
      echo "ok"
    fi
    ;;
esac

# 3. The error message must mention CompressionNotSupported.
case "$err" in
  *CompressionNotSupported*) echo "ok" ;;
  *) echo "not ok" ;;
esac

# 4. The +strict toggle must restore the silent fallback.
${MAGICK} -strict +strict ${SRCDIR}/rose.pnm -compress JBIG2 "$out" 2>/dev/null \
  && echo "ok" || echo "not ok"

# 5. -strict combined with a supported codec must still succeed.
${MAGICK} -strict ${SRCDIR}/rose.pnm -compress LZW "$out" 2>/dev/null \
  && echo "ok" || echo "not ok"

# 6. Without -strict, the unsupported-compression warning must reach stderr
# so users see why their file was not written with the requested codec.
# -strict is the gate that promotes this warning into a non-zero exit.
err=`${MAGICK} ${SRCDIR}/rose.pnm -compress JBIG2 "$out" 2>&1`
case "$err" in
  *CompressionNotSupported*) echo "ok" ;;
  *) echo "not ok" ;;
esac

:

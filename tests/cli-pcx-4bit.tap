#!/bin/sh

. ./common.shi
. ${srcdir}/tests/common.shi

echo "1..5"

# check PCX header bytes: bit depth (offset 3) and plane count (offset 65)
check_header() {
  file=$1
  expected_bits=$2
  expected_planes=$3
  label=$4
  result=0

  bits=$(printf '%d' "0x$(xxd -s 3 -l 1 "$file" | awk '{print $2}')")
  if [ "$bits" -ne "$expected_bits" ]; then
    echo "Failure: $label bits per pixel expected $expected_bits, got $bits"
    result=1
  fi

  planes=$(printf '%d' "0x$(xxd -s 65 -l 1 "$file" | awk '{print $2}')")
  if [ "$planes" -ne "$expected_planes" ]; then
    echo "Failure: $label planes expected $expected_planes, got $planes"
    result=1
  fi

  return $result
}

# =====================================================================
# test 1: 4-bit encoding (1 bit per pixel, 4 planes, <= 16 colors)
# =====================================================================
${MAGICK} ${SRCDIR}/rose.pnm -colors 16 /tmp/4bit-test.pcx

error=false
check_header /tmp/4bit-test.pcx 1 4 "4-bit" || error=true
$error && echo "not ok" || echo "ok"

# =====================================================================
# test 2: monochrome encoding (1 bit per pixel, 1 plane)
# =====================================================================
${MAGICK} ${SRCDIR}/rose.pnm -threshold 50% -type Bilevel /tmp/mono-test.pcx

error=false
check_header /tmp/mono-test.pcx 1 1 "monochrome" || error=true
$error && echo "not ok" || echo "ok"

# =====================================================================
# test 3: 8-bit indexed encoding (8 bits per pixel, 1 plane)
# =====================================================================
${MAGICK} ${SRCDIR}/rose.pnm +dither -colors 256 /tmp/indexed-test.pcx

error=false
check_header /tmp/indexed-test.pcx 8 1 "8-bit indexed" || error=true
$error && echo "not ok" || echo "ok"

# =====================================================================
# test 4: RGB encoding (8 bits per pixel, 3 planes)
# =====================================================================
${MAGICK} ${SRCDIR}/rose.pnm /tmp/rgb-test.pcx

error=false
check_header /tmp/rgb-test.pcx 8 3 "RGB" || error=true
$error && echo "not ok" || echo "ok"

# =====================================================================
# test 5: RGBA encoding (8 bits per pixel, 4 planes)
# =====================================================================
${MAGICK} ${SRCDIR}/rose.pnm -alpha set /tmp/rgba-test.pcx

error=false
check_header /tmp/rgba-test.pcx 8 4 "RGBA" || error=true
$error && echo "not ok" || echo "ok"
